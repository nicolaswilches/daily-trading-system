---
import Layout from "../layouts/Layout.astro";
import StatTile from "../components/StatTile.astro";
import { loadPredictions, loadMethodology } from "../lib/data";

const { predictions, generated_at, cutoff_date } = loadPredictions();
const methodology = loadMethodology();

const buyCount = predictions.filter((p) => p.signal === "BUY").length;
const sellCount = predictions.filter((p) => p.signal === "SELL").length;
const holdCount = predictions.filter((p) => p.signal === "HOLD").length;

const lastUpdated = new Date(generated_at).toLocaleString("en-US", {
  dateStyle: "medium",
  timeStyle: "short",
  timeZone: "UTC",
});

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Layout title="Overview">
  <section class="mb-12">
    <h1 class="text-4xl font-semibold tracking-tight">
      Next-day forecasts for US equities
    </h1>
    <p class="mt-3 text-lg max-w-2xl" style="color: var(--text-muted);">
      Two LightGBM models — direction and magnitude — generate daily BUY/SELL/HOLD
      signals for five major tickers. All results shown are strictly out-of-sample.
    </p>
    <p class="mt-4 text-xs num" style="color: var(--text-subtle);">
      Last updated {lastUpdated} UTC · Holdout cutoff {cutoff_date}
    </p>
  </section>

  <section class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
    <StatTile label="BUY signals" value={String(buyCount)} tone="positive" />
    <StatTile label="SELL signals" value={String(sellCount)} tone="negative" />
    <StatTile label="HOLD" value={String(holdCount)} />
    <StatTile
      label="Holdout precision"
      value={(methodology.metrics.holdout_precision * 100).toFixed(1) + "%"}
      hint={`vs ${(methodology.metrics.cv_precision * 100).toFixed(1)}% CV`}
    />
  </section>

  <section class="mb-12">
    <div class="flex items-baseline justify-between mb-4">
      <h2 class="text-xl font-semibold">Today's signals</h2>
      <a
        href={`${base}/predictions`}
        class="text-sm btn-ghost hover:underline"
      >
        Per-ticker detail →
      </a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
      {
        predictions.map((p) => {
          const change = p.change_pct;
          const toneClass =
            p.signal === "BUY"
              ? "signal-buy"
              : p.signal === "SELL"
                ? "signal-sell"
                : "signal-hold";
          return (
            <a
              href={`${base}/predictions#${p.ticker}`}
              class="card p-5 transition hover:scale-[1.01]"
            >
              <div class="flex items-center justify-between">
                <span class="font-semibold">{p.ticker}</span>
                <span class={`text-xs font-medium ${toneClass}`}>{p.signal}</span>
              </div>
              <div class="num text-2xl mt-3">${p.current_price.toFixed(2)}</div>
              <div
                class={`num text-sm mt-1 ${change >= 0 ? "signal-buy" : "signal-sell"}`}
              >
                {change >= 0 ? "+" : ""}{change.toFixed(2)}%
              </div>
              <div
                class="text-xs mt-3 num"
                style="color: var(--text-muted);"
              >
                Target ${p.target_price.toFixed(2)} ·{" "}
                {(p.prob_up * 100).toFixed(0)}% up
              </div>
            </a>
          );
        })
      }
    </div>
  </section>

  <section class="card p-6">
    <h2 class="text-lg font-semibold mb-2">How it works</h2>
    <ul class="space-y-2 text-sm" style="color: var(--text-muted);">
      <li>
        <strong class="text-[color:var(--text)]">Features:</strong>{" "}
        {methodology.feature_count} engineered features — trend, momentum,
        volatility, fundamentals — joined point-in-time to avoid lookahead.
      </li>
      <li>
        <strong class="text-[color:var(--text)]">Split:</strong>{" "}
        {methodology.split.train_rows.toLocaleString()} training rows through{" "}
        {cutoff_date}, {methodology.split.holdout_rows.toLocaleString()} holdout
        rows after. Optuna tuning and final fit only on the train portion.
      </li>
      <li>
        <strong class="text-[color:var(--text)]">Refresh:</strong> GitHub
        Actions runs inference daily after the US close and rebuilds this
        static site.
      </li>
    </ul>
  </section>
</Layout>
