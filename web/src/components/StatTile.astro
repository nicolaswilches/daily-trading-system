---
interface Props {
  label: string;
  value: string;
  hint?: string;
  tone?: "neutral" | "positive" | "negative" | "accent";
}
const { label, value, hint, tone = "neutral" } = Astro.props;
const toneClass = {
  neutral: "",
  positive: "signal-buy",
  negative: "signal-sell",
  accent: "",
}[tone];
const toneStyle = tone === "accent" ? "color: var(--accent);" : "";
---

<div class="card px-4 py-3">
  <div class="text-xs uppercase tracking-wide" style="color: var(--text-subtle);">
    {label}
  </div>
  <div class={`num text-2xl mt-1 ${toneClass}`} style={toneStyle}>
    {value}
  </div>
  {
    hint && (
      <div class="text-xs mt-1" style="color: var(--text-muted);">
        {hint}
      </div>
    )
  }
</div>
